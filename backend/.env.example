# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to GitHub — it's already in .gitignore.

# PostgreSQL connection string
# Local example: postgresql://postgres:postgres@localhost:5432/ethara_seating
# Railway gives you this automatically when you add a Postgres plugin
# (use the "Variables" tab on your Postgres service to copy it).
DATABASE_URL=postgresql://postgres:your_password@your-host:5432/railway

# Needed only for the AI Assistant (/ai/query) endpoint — text-to-SQL step.
# Get one from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Needed only for the AI Assistant's plain-English summarization step.
# Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Used to sign login tokens. Set this to any long random string in production.
JWT_SECRET_KEY=change-this-to-a-random-secret-string
